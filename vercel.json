{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/catch", "destination": "/api/catch" },
    { "source": "/api/(.*)", "destination": "/api/catch?path=$1" },
    { "source": "/sketches", "destination": "/index.html" },
    { "source": "/sketches/:path*", "destination": "/index.html" },
    { "source": "/collections", "destination": "/index.html" },
    { "source": "/collections/:path*", "destination": "/index.html" },
    { "source": "/home", "destination": "/index.html" },
    { "source": "/timeline", "destination": "/index.html" },
    { "source": "/s/:path*", "destination": "/index.html" },
    { "source": "/", "destination": "/index.html" }
  ]
}
