# Entry code for the gate (4 digits). Default: 1234
VITE_ENTRY_CODE=1234

# Optional: API base URL (default: same origin with Vite proxy)
# VITE_API_URL=http://localhost:3001

# Supabase (frontend – optional, required for direct sketch upload)
# For sketch uploads > 4.5 MB the client uploads directly to Supabase; without these, uploads go through the API and are limited by Vercel's body size (~4.5 MB).
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Server
PORT=3001
# UPLOAD_DIR=./data/uploads
# BASE_URL=http://localhost:5173

# Database (required): Supabase REST. From Dashboard → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage (optional): store audio in a Supabase bucket instead of local disk
# USE_SUPABASE_STORAGE=true
# SUPABASE_STORAGE_BUCKET=audio
