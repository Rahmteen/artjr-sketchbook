# Entry code for the gate (4 digits). Default: 1234
VITE_ENTRY_CODE=1234

# Optional: API base URL (default: same origin with Vite proxy)
# VITE_API_URL=http://localhost:3001

# Supabase (frontend – optional)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Server
PORT=3001
# SQLITE_DIR=./data
# UPLOAD_DIR=./data/uploads
# BASE_URL=http://localhost:5173

# Supabase (server only – service_role from Dashboard → Project Settings → API)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage: store audio in a bucket instead of local disk (requires SUPABASE_URL + key above)
# USE_SUPABASE_STORAGE=true
# SUPABASE_STORAGE_BUCKET=audio

# Supabase Postgres (direct connection – from Dashboard → Project Settings → Database)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
